{
    "name": "openai-to-vertex",
    "version": "1.0.0",
    "description": "OpenAI-compatible API proxy service forwarding requests to Google Vertex AI",
    "main": "dist/app.js",
    "scripts": {
        "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/app.js",
        "start": "node dist/app.js",
        "dev": "tsx watch src/index.ts"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "license": "MIT",
    "dependencies": {
        "@fastify/cors": "^11.2.0",
        "@fastify/env": "^6.0.0",
        "@fastify/rate-limit": "^10.3.0",
        "@google/genai": "^2.8.0",
        "fastify": "^5.8.5",
        "google-auth-library": "^9.15.1",
        "pino": "^9.6.0",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@types/node": "^22.15.0",
        "esbuild": "^0.28.0",
        "tsx": "^4.19.0",
        "typescript": "^5.8.0"
    }
}
